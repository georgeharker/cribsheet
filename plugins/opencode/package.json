{
    "name": "@geohar/opencode-cribsheet",
    "version": "0.5.1",
    "description": "OpenCode plugin: run the crib (cribsheet) memory + code-index MCP server via sharedserver, register its endpoint, inject the reach-for-crib directive, and ship the /crib command. Stands down when a combiner already serves crib.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "instructions.txt",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "prepack": "node -e \"require('fs').copyFileSync('../../CLAUDE.md.example', './instructions.txt')\"",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "keywords": [
        "opencode",
        "opencode-plugin",
        "mcp",
        "cribsheet",
        "crib",
        "memory",
        "code-index",
        "sharedserver",
        "plugin"
    ],
    "author": "George Harker <george@georgeharker.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/georgeharker/cribsheet.git",
        "directory": "plugins/opencode"
    },
    "bugs": {
        "url": "https://github.com/georgeharker/cribsheet/issues"
    },
    "homepage": "https://github.com/georgeharker/cribsheet/tree/main/plugins/opencode#readme",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.3.0"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.3.0",
        "@types/node": "^22.0.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
